{
  "cleanupPeriodDays": 15,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "Bash(cd:*)",
      "Bash(curl:*)",
      "Bash(date +%s)",
      "Bash(date +%s > ~/.claude/last-session-save-timestamp)",
      "Bash(docker compose up:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git init:*)",
      "Bash(git mv:*)",
      "Bash(git remote add:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(git worktree:*)",
      "Bash(kill:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(netstat:*)",
      "Bash(node -e:*)",
      "Bash(npm audit fix:*)",
      "Bash(npm install)",
      "Bash(npm run:*)",
      "Bash(npm run dev:*)",
      "Bash(npx tsc:*)",
      "Bash(pgrep:*)",
      "Bash(pip3 install:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(source:*)",
      "Bash(ss:*)",
      "Bash(sudo tee:*)",
      "Bash(tree:*)",
      "Bash(venv/bin/python:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "Bash(xargs cat:*)",
      "Bash(xargs kill:*)",
      "Skill(brain-check)",
      "Skill(brain-check:*)",
      "Skill(capture)",
      "Skill(capture:*)",
      "Skill(commit)",
      "Skill(commit:*)",
      "Skill(save-lightweight)",
      "Skill(save-lightweight:*)",
      "Skill(save-session)",
      "Skill(save-session:*)",
      "Skill(start-session)",
      "Skill(start-session:*)",
      "Skill(vault-search)",
      "Skill(vault-search:*)"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false
  },
  "outputStyle": "Concise and direct. Lead with the answer. No filler or preamble.",
  "effortLevel": "medium",
  "fastModePerSessionOptIn": true,
  "promptSuggestionEnabled": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.85",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true,
  "defaultView": "transcript",
  "theme": "dark-ansi",
  "fileCheckpointingEnabled": false,
  "remoteControlAtStartup": false
}
